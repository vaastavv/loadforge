{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Observability overview for the LoadForge distributed load testing platform. Metrics are scraped from the controller (test-management-service) and worker (worker-service) via Spring Boot Actuator + Micrometer at /actuator/prometheus.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["loadforge", "load-testing", "prometheus"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "LoadForge — Load Testing Overview",
  "uid": "loadforge-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "1 — Active Workers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Workers Executing (BUSY)",
      "id": 2,
      "description": "Workers currently running an execution — custom gauge `loadforge_worker_active_executions` (worker-service, workers in BUSY state).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(loadforge_worker_active_executions{application=\"worker-service\"})",
          "legendFormat": "busy workers",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Worker Instances Up",
      "id": 3,
      "description": "Live worker-service scrape targets — Prometheus `up` for the `worker` job (see prometheus.yml). Reflects the number of running worker processes.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(up{job=\"worker\"} == 1)",
          "legendFormat": "workers up",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Tests (controller)",
      "id": 4,
      "description": "Load tests currently running — custom gauge `loadforge_controller_active_tests` (test-management-service, executions in RUNNING state).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(loadforge_controller_active_tests{application=\"test-management-service\"})",
          "legendFormat": "running tests",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "2 — Requests Per Second",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "API Requests / sec",
      "id": 6,
      "description": "Request rate on the control-plane API (test-management-service), overall and per endpoint (`uri`), from the Micrometer `http_server_requests` timer. NOTE: this is the platform's own API throughput, not the synthetic load workers generate against a target system.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"test-management-service\"}[$__rate_interval]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"test-management-service\"}[$__rate_interval]))",
          "legendFormat": "{{uri}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "3 — Throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Throughput — successful requests / sec",
      "id": 8,
      "description": "Successfully served requests per second (`outcome=SUCCESS`) per service. Represents useful processed throughput across the platform APIs, distinct from raw request rate which includes errors.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{outcome=\"SUCCESS\"}[$__rate_interval]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "4 — P95 Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "P95 Response Latency",
      "id": 10,
      "description": "95th percentile HTTP response latency per service, computed from `http_server_requests_seconds_bucket` (percentiles-histogram enabled in application.yml) via histogram_quantile.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "P95 — controller (now)",
      "id": 11,
      "description": "Current 95th percentile latency of the control-plane API (test-management-service).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"test-management-service\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "5 — P99 Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 12,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "P99 Response Latency",
      "id": 13,
      "description": "99th percentile HTTP response latency per service, from `http_server_requests_seconds_bucket` via histogram_quantile. Highlights tail latency / worst-case responses.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, application) (rate(http_server_requests_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "P99 — controller (now)",
      "id": 14,
      "description": "Current 99th percentile (tail) latency of the control-plane API (test-management-service).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"test-management-service\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "6 — Error Rate",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 15,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Error Rate %",
      "id": 16,
      "description": "Percentage of requests resulting in server (outcome=SERVER_ERROR / 5xx) and client (outcome=CLIENT_ERROR / 4xx) errors across the platform APIs. Series show gaps when there is no traffic in the window.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 43 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{outcome=\"SERVER_ERROR\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count[$__rate_interval])))",
          "legendFormat": "5xx %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{outcome=\"CLIENT_ERROR\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count[$__rate_interval])))",
          "legendFormat": "4xx %",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Server Error Rate (now)",
      "id": 17,
      "description": "Current share of requests returning 5xx (outcome=SERVER_ERROR) across the platform APIs. Green < 1%, amber 1–5%, red ≥ 5%.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 43 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{outcome=\"SERVER_ERROR\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count[$__rate_interval])))",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "7 — Resource Usage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "id": 18,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "id": 19,
      "description": "Process CPU utilisation per service (Micrometer `process_cpu_usage` × 100). Covers the worker CPU requirement and the controller. Host-level `system_cpu_usage` is also available if needed.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{application=~\"test-management-service|worker-service\"} * 100",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used vs Max",
      "id": 20,
      "description": "JVM heap memory used vs max per service (`jvm_memory_used_bytes` / `jvm_memory_max_bytes`, area=heap). Covers the worker memory requirement and the controller.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}} used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "{{application}} max",
          "refId": "B"
        }
      ]
    }
  ]
}
